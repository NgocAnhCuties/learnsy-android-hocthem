# Copy file này thành "local.properties" (không có .example) và điền giá trị thật.
# File local.properties đã được .gitignore chặn — KHÔNG BAO GIỜ commit lên GitHub.

sdk.dir=/path/to/your/Android/sdk

SUPA_URL=https://xxxxx.supabase.co
SUPA_KEY=your-anon-key-here

UPSTASH_URL=https://xxxxx.upstash.io
UPSTASH_TOKEN=your-upstash-rest-token-here
